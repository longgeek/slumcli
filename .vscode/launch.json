{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "slumcli: 现在几点",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/slumcli/main.py",
      "args": ["现在几点了"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    },
    {
      "name": "slumcli: 交互模式",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/slumcli/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true
    }
  ]
}
